        <!-- Script 01 -->
        <mxCell id="s01-box" value="01_setup_aws_oidc.sh&#xa;─────────────────────&#xa;Creates in AWS:&#xa;• OIDC Identity Provider&#xa;  (token.actions.githubusercontent.com)&#xa;• IAM Role: github-actions-oidc-role&#xa;  + EC2Full, S3Full, IAMFull&#xa;&#xa;Outputs GitHub Secret:&#xa;  AWS_ROLE_ARN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2D1B1B;strokeColor=#FF6B6B;strokeWidth=2;fontColor=#FFC0C0;arcSize=12;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="270" width="380" height="120" as="geometry"/>
        </mxCell>

        <!-- Script 02 -->
        <mxCell id="s02-box" value="02_setup_s3_backend.sh&#xa;─────────────────────&#xa;Creates in AWS:&#xa;• S3 Bucket (Terraform backend)&#xa;  [Versioning + Object Lock + SSE]&#xa;&#xa;Outputs GitHub Secret:&#xa;  TF_VAR_tf_state_bucket" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1B2D2B;strokeColor=#00A8E8;strokeWidth=2;fontColor=#C0F0FF;arcSize=12;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;" vertex="1" parent="1">
